# Secrets/config for the off-Cloudflare Telegram ingest (scripts/ingest_local.py).
# Copy to a SECURED file on the VPS (e.g. /etc/tg-crm-ingest.env), then:
#   sudo chmod 600 /etc/tg-crm-ingest.env
# Never commit the filled-in version.

# Telegram (same values you used for login.py / the Worker secrets)
TG_API_ID=
TG_API_HASH=
TG_SESSION=

# Cloudflare API token with D1:Edit on the plex.engineer account
CF_API_TOKEN=

# Optional — defaults are baked into the script; only set to override:
# CF_ACCOUNT_ID=4efa81edb9dfe313cb1636ef5f9206f3
# CF_D1_DATABASE_ID=43a788cc-7c4d-4e76-a12f-7a858b8bd17b
# FETCH_LIMIT_PER_CHAT=200
# MAX_CHATS=0
