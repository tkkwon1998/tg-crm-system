[Unit]
Description=Run Telegram ingest every hour

[Timer]
# First run 2 min after boot, then every hour after each run completes.
OnBootSec=2min
OnUnitActiveSec=1h
# Catch up a run if the box was asleep/offline at the scheduled time.
Persistent=true
AccuracySec=30s

[Install]
WantedBy=timers.target
