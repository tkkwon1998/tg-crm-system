{
  "name": "tg-crm-system",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram -> Attio CRM enrichment, Cloudflare-native monorepo (terminal-only operating model).",
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "bash scripts/deploy-all.sh",
    "status": "bash scripts/status.sh"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.0",
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9",
    "wrangler": "^4.20.0"
  }
}
