{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "extract",
  "account_id": "4efa81edb9dfe313cb1636ef5f9206f3",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },

  // Cron: pick up un-extracted threads, fan out one Workflow per thread. Offset
  // ~3 min after ingest's */10 so it processes the same cycle's new messages.
  // A few minutes of latency is acceptable (spec §1). Overlaps are safe —
  // getUnextractedMessages + markMessagesExtracted are idempotent.
  "triggers": {
    "crons": ["3,13,23,33,43,53 * * * *"]
  },

  // Shared D1 database. Binding name MUST be "DB" (contract). database_id is
  // filled in by `make bootstrap`.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "crm",
      "database_id": "43a788cc-7c4d-4e76-a12f-7a858b8bd17b"
    }
  ],

  // Durable per-thread pipeline: resolve -> extract -> propose. Binding name
  // MUST be "EXTRACT_WORKFLOW" (contract).
  "workflows": [
    {
      "binding": "EXTRACT_WORKFLOW",
      "name": "crm-extract-pipeline",
      "class_name": "ExtractWorkflow"
    }
  ],

  "vars": {
    // Fuzzy chat-title -> deal score at/above which a CLEAR winner auto-confirms
    // (must still beat the runner-up by the disambiguation margin). Lowered to
    // 0.78 so "X <> Theo" style titles (e.g. RockawayX/Fasanara ~0.80) auto-link.
    "DEAL_AUTO_CONFIRM_SCORE": "0.78"
  }

  // Secrets (set with `wrangler secret put <NAME>` from this dir, or via
  // .dev.vars locally): ANTHROPIC_API_KEY, ATTIO_TOKEN.
}
