{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "apply",
  "account_id": "4efa81edb9dfe313cb1636ef5f9206f3",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },

  // Cron-driven (spec §5.4). Runs a few minutes behind ingest/extract; CRM
  // enrichment tolerates minutes of latency. Idempotent on proposal status,
  // so overlapping/retried runs are safe.
  // Offset ~6 min after ingest's */10 so a freshly-extracted proposal applies in
  // the same cycle. Idempotent on proposal status, so overlaps/retries are safe.
  "triggers": {
    "crons": ["6,16,26,36,46,56 * * * *"]
  },

  // Shared D1 — binding name MUST be "DB", database_name "crm". The
  // database_id is filled in by `make bootstrap`.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "crm",
      "database_id": "43a788cc-7c4d-4e76-a12f-7a858b8bd17b"
    }
  ],

  // Non-secret tuning knobs (spec §8: thresholds live in wrangler.jsonc).
  // ATTIO_TOKEN is a secret — set with `wrangler secret put ATTIO_TOKEN`.
  "vars": {
    // Auto-apply gate: proposals at/above this confidence whose changed
    // attributes are ALL on the safe allowlist apply without human approval.
    "AUTO_APPLY_CONFIDENCE_THRESHOLD": "0.9",
    // Comma-separated safe attribute slugs eligible for auto-apply (PEOPLE).
    "SAFE_ATTRIBUTE_ALLOWLIST": "phone,phone_numbers,email,email_addresses,job_title,title",
    // DEAL field map: Claude semantic slug = real Attio deal attribute slug.
    // EMPTY = notes-only mode (no deal field is changed). Field suggestions are
    // surfaced inside the provenance note instead. To enable field writes later,
    // add pairs, e.g. "next_step=next_due_task_4,next_step_date=next_due_task_date".
    "DEAL_FIELD_MAP": "",
    // Associating participants edits a deal field too — off for notes-only mode.
    // Set "true" later to link confirmed participants on the deal.
    "ATTIO_LINK_PARTICIPANTS": "false",
    // Attribute slug used to dedupe (matching_attribute) on assert_person.
    "ATTIO_PEOPLE_MATCHING_ATTRIBUTE": "email_addresses",
    // The Deals attribute holding associated people (record reference). Attio's
    // standard Deals object uses "associated_people"; override if yours differs.
    "ATTIO_DEAL_PEOPLE_ATTRIBUTE": "associated_people",
    // Attio API base.
    "ATTIO_API_BASE": "https://api.attio.com",
    // Max proposals processed per cron tick (bounds run time / API spend).
    "APPLY_BATCH_LIMIT": "50"
  }
}
