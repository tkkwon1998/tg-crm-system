{
  "name": "@crm/db",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical D1 schema + shared TS types + typed D1 client for the Telegram->Attio CRM system.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./schema.sql": "./schema.sql"
  },
  "files": [
    "src",
    "schema.sql",
    "migrations"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.0",
    "typescript": "^5.5.4"
  }
}
